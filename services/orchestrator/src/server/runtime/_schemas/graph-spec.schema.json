{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-loom.local/schemas/graph-spec.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "graphSpecVersion",
    "id",
    "name",
    "rootRepoPath",
    "baseBranch",
    "status",
    "revision",
    "createdAt",
    "updatedAt",
    "nodes",
    "edges"
  ],
  "properties": {
    "graphSpecVersion": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "rootRepoPath": { "type": "string", "minLength": 1 },
    "baseBranch": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "archived"] },
    "revision": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "label", "cli", "prompt", "position"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "const": "execute" },
          "label": { "type": "string", "minLength": 1 },
          "cli": { "enum": ["fake", "codex", "kiro", "gemini", "claude"] },
          "prompt": { "type": "string", "minLength": 1 },
          "position": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "source", "target"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "const": "flow" },
          "source": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
