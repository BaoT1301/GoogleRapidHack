# ============================================================================
# GoogleRapidHack — local client environment (BFF mode)
#
# Copy this file to  .env.orchestrator  at the REPO ROOT, then fill in values:
#     cp .env.example .env.orchestrator
# The orchestrator loads env from <repo-root>/.env.orchestrator (see
# services/orchestrator/next.config.ts).
#
# This is the LOCAL client. Data + secrets live on the deployed cloud BFF; the
# client only needs the public config below. NEVER put DB/Clerk-secret/vault
# values here (see the bottom of this file).
# ============================================================================

# ── Clerk (sign-in) — PUBLISHABLE key only; safe to commit (browser-exposed) ─
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YmVjb21pbmctZ2xvd3dvcm0tODguY2xlcmsuYWNjb3VudHMuZGV2JA
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cloud Auth/BFF (the data layer) — deployed endpoint (public URL, not a secret) ─
# All DB/secret access is proxied through this; the client holds NO DB creds.
BFF_URL=https://auth-bff-gkmvodonrq-uc.a.run.app

# ── LLM Architect API (planning + embeddings) ────────────────────────────────
# LLM_API_URL is a public Cloud Run endpoint (safe to commit). The TOKEN is the
# ONLY secret here — it is intentionally a placeholder. Get the real demo value
# from the submission's PRIVATE judge notes and paste it into your local
# .env.orchestrator (which is gitignored). NEVER commit the real token.
LLM_API_URL=https://llm-architect-gkmvodonrq-uc.a.run.app
# LLM_SERVICE_TOKEN=orch-1448db74f8e10ca553bb0f5a4e1ffef86d30

# ── Knowledge-base embeddings (optional) ─────────────────────────────────────
ORCH_KB_EMBEDDINGS=1

# ── Auto-merge agent branches back to base (true/false) ──────────────────────
ORCH_AUTO_MERGE=true

# ── mcp-context-manager reachability ─────────────────────────────────────────
# docker  → dev; requires `./mcp.sh up` (a running mcp-context-manager container)
# node    → packaged; requires a built dist/server.js at MCP_CONTEXT_MANAGER_PATH
MCP_CONTEXT_MANAGER_MODE=docker
# MCP_CONTEXT_MANAGER_PATH=

# ── MongoDB MCP — DISABLED on the client (DECISION-2) ────────────────────────
# Enabling it would require shipping DB credentials to the client. Keep 0.
ENABLE_MCP_MONGODB=0
# MDB_MCP_CONNECTION_STRING=   # BFF-side only — never put real DB creds here

# ── Interactive worktree shell (PTY over WebSocket), localhost-bound ─────────
ORCH_PTY_WS_PORT=3031
NEXT_PUBLIC_ORCH_PTY_WS_PORT=3031
ORCH_PTY_IDLE_MS=600000

# ============================================================================
# NEVER put these on the client — they live ONLY on the deployed BFF:
#   MONGODB_URI, CLERK_SECRET_KEY, VAULT_PASSPHRASE,
#   BFF_SERVICE_TOKEN, BFF_RUN_TOKEN_SIGNING_KEY
# ============================================================================
